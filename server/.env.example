PORT=3000
AUTH_MODE=dev

# Used in dev mode only.
DEV_JWT_SECRET=replace_with_a_long_random_secret
DEV_TOKEN_EXPIRES_IN=2h

# Used in cognito mode only.
COGNITO_REGION=us-east-1
COGNITO_USER_POOL_ID=replace_me
COGNITO_APP_CLIENT_ID=replace_me
COGNITO_ISSUER=https://cognito-idp.us-east-1.amazonaws.com/replace_me

# Cognito app client must allow USER_PASSWORD_AUTH for /auth/login.
