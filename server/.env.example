LEGACY_SERVER_PORT=3000
# Railway sets PORT automatically in production.
# PORT=3000
AUTH_MODE=cognito
COGNITO_REGION=us-east-2
COGNITO_USER_POOL_ID=replace_me
COGNITO_APP_CLIENT_ID=replace_me
COGNITO_ISSUER=https://cognito-idp.us-east-2.amazonaws.com/replace_me
# Comma-separated list, e.g. https://your-web.vercel.app,https://nestsync-production.up.railway.app
# CORS_ORIGINS=http://localhost:3000

# Rooms: omit DynamoDB table names to use in-memory store (dev). Set both for AWS DynamoDB.
# ROOM_STORE=auto
# DYNAMODB_ROOMS_TABLE=NestSyncRooms
# DYNAMODB_MESSAGES_TABLE=NestSyncRoomMessages
